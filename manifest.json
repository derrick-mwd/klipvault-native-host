{
  "manifest_version": 3,
  "name": "KlipVault Video Downloader",
  "version": "1.2.6",
  "description": "Companion browser extension for KlipVault (https://klipvault.xyz). Downloads videos from YouTube, TikTok, Instagram, X, Reddit, Twitch, Vimeo, and more using yt-dlp. Enables HLS stream downloads and automatic cookie extraction for authenticated platforms.",
  "permissions": [
    "downloads",
    "storage",
    "activeTab",
    "scripting",
    "nativeMessaging",
    "cookies"
  ],
  "host_permissions": [
    "https://klipvault.xyz/*",
    "https://*.googlevideo.com/*",
    "https://*.vimeocdn.com/*",
    "https://*.dmcdn.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://klipvault.xyz/*",
            "https://www.youtube.com/*",
        "https://vimeo.com/*",
        "https://www.dailymotion.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "https://klipvault.xyz/*"
    ]
  }
}
